# Application Configuration
GO_ENV=development
PORT=8080

# CORS Configuration (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# AWS Configuration (for DynamoDB)
AWS_REGION=ap-northeast-1
DYNAMODB_ENDPOINT=http://dynamodb:8000
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy

# Google OAuth - Get these from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# JWT Secret - Use a strong, random string in production
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Root User Configuration
# Email address that will be granted root/admin privileges
# This user is created automatically on application startup
ROOT_USER_EMAIL=admin@yourdomain.com

# Gemini API Configuration
# Get your API key from https://ai.google.dev/
GOOGLE_AI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=8192
GEMINI_TOP_P=0.95

# OpenAI API Configuration
# Get your API key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o
# OPENAI_TEMPERATURE=0.7
# OPENAI_MAX_TOKENS=8192
# OPENAI_TOP_P=0.95

# Anthropic API Configuration
# Get your API key from https://console.anthropic.com/
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_TEMPERATURE=0.7
# ANTHROPIC_MAX_TOKENS=8192
# ANTHROPIC_TOP_P=0.95

# ADK Application Settings
ADK_APP_NAME=go-adk-chat
ADK_APP_VERSION=1.0.0
ADK_APP_DESCRIPTION=AI Chat Assistant with Memory

# Chat DynamoDB Tables (optional - defaults to constructed names)
# DYNAMODB_CHAT_THREADS_TABLE=go-adk-chat-dev-chat-threads
# DYNAMODB_CHAT_SESSIONS_TABLE=go-adk-chat-dev-chat-sessions
# DYNAMODB_CHAT_EVENTS_TABLE=go-adk-chat-dev-chat-events
# DYNAMODB_CHAT_MEMORIES_TABLE=go-adk-chat-dev-chat-memories
